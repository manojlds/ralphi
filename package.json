{
  "name": "@manojlds/ralphi",
  "version": "0.6.0",
  "description": "Pi-native ralph extension with skill commands and fresh-context loop sessions.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "ralphi",
    "ralph"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manojlds/ralphi.git"
  },
  "homepage": "https://github.com/manojlds/ralphi",
  "bugs": "https://github.com/manojlds/ralphi/issues",
  "bin": {
    "ralphi": "bin/ralphi.js"
  },
  "scripts": {
    "test:unit:ralphi-extension": "vitest run --config vitest.config.ts",
    "test:unit:ralphi-extension:watch": "vitest --config vitest.config.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test:unit:ralphi-extension",
    "ralphi:check": "node ./bin/ralphi.js check"
  },
  "pi": {
    "extensions": [
      "extensions/ralphi/index.ts"
    ],
    "skills": [
      "skills/ralphi-init/SKILL.md",
      "skills/ralphi-prd/SKILL.md",
      "skills/ralphi-convert/SKILL.md",
      "skills/ralphi-loop/SKILL.md"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.4"
  }
}
